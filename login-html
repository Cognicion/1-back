<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Acceso</title>

<style>

body{
    font-family:Arial;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:#f0f2f5;
}

.card{
    background:white;
    padding:30px;
    border-radius:20px;
    width:300px;
    box-shadow:0 0 15px rgba(0,0,0,.15);
}

input{
    width:100%;
    padding:10px;
    margin:10px 0;
}

button{
    width:100%;
    padding:12px;
    border:none;
    background:#2b7de9;
    color:white;
    border-radius:10px;
}

</style>

</head>

<body>

<div class="card">

<h2>Iniciar sesión</h2>

<input type="email" id="email" placeholder="Correo">

<input type="password" id="password" placeholder="Contraseña">

<button id="loginBtn">
Entrar
</button>

</div>

<script type="module" src="firebase.js"></script>

</body>
</html>
